              <a:rPr lang="en-US" sz="3000" b="1" dirty="0"/>
              <a:t>1. DETECT — Fixed sensors and CCTV network continuously scan urban grid for anomalies</a:t>
            </a:r>
          </a:p>
          <a:p>
