            <a:r>
              <a:rPr lang="en-US" sz="3200" b="1" dirty="0"/>
              <a:t>2. CLASSIFY — AI model identifies incident type (accident, crowd surge, fire, crime) in under 200ms with 99.2% accuracy</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:pPr marL="457200" indent="-457200">
