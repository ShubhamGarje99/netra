          </a:p>
          <a:p>
            <a:pPr algn="ctr"/>
            <a:r>
              <a:rPr lang="en-US" sz="3200" b="1" dirty="0"/>
              <a:t>India&#x2019;s first fully autonomous urban aerial response system &#x2014; not a product, a city safety infrastructure layer</a:t>
