          </a:p>
          <a:p>
            <a:pPr algn="ctr"/>
            <a:r>
              <a:rPr lang="en-US" sz="3200" b="1" dirty="0"/>
              <a:t>Reduces average emergency response time from 16+ minutes to under 2.5 minutes &#x2014; 6x faster than current police dispatch</a:t>
