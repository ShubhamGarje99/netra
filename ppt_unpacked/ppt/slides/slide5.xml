            </a:pPr>
            <a:r>
              <a:rPr lang="en-US" sz="3000" b="1" dirty="0"/>
              <a:t>Why YOLO: Sub-200ms inference, runs edge-deployable on drone payload hardware, handles real-time video streams at 30 FPS</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:pPr marL="285750" indent="-285750">
