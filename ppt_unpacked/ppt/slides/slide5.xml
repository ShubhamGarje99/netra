              <a:buChar char="•"/>
            </a:pPr>
            <a:r>
              <a:rPr lang="en-US" sz="3000" b="1" dirty="0"/>
              <a:t>Frontend: Next.js 16 (App Router), React 18, Tailwind CSS, GSAP + Lenis (scroll), anime.js v4 (UI), Three.js (3D)</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:pPr marL="285750" indent="-285750">
