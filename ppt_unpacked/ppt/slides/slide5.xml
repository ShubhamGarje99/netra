            <a:r>
              <a:rPr lang="en-US" sz="3000" b="1" dirty="0"/>
              <a:t>AI/ML: Computer vision pipeline with real-time object detection and incident classification. YOLO-based model fine-tuned on Indian urban incident data (accident, crowd, fire, crime categories).</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:pPr marL="742950" lvl="1" indent="-285750">
