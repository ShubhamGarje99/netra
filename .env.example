# Random mock incident generation is hard-disabled in code for judge-safe demos.
ENABLE_MOCK_GENERATOR=false

# YOLOv8 detector service URL (Python FastAPI backend).
NEXT_PUBLIC_DETECTOR_URL=http://localhost:8000

# Next.js app URL for detector to post events back.
NETRA_APP_URL=http://localhost:3000

# PostgreSQL connection for persistent runtime state and detector event log.
# Example: postgres://netra:netra@localhost:5432/netra
DATABASE_URL=

# Set true only if your managed Postgres requires TLS.
DATABASE_SSL=false

# Optional: Protect POST /api/incidents with this API key via x-api-key header.
NETRA_INGEST_API_KEY=

# Optional: Protect POST /api/detector/events with this API key via x-api-key header.
# If set, pass the same key to the detector: python detect.py --api-key <key>
NETRA_DETECTOR_API_KEY=

# Detector: consecutive inference frames required before an alert is sent (false-positive filter). Default 2.
# DETECTOR_CONFIRM_FRAMES=2
# DETECTOR_VEHICLE_STOP_SECONDS=10
# DETECTOR_ABANDONED_STATIONARY_SECONDS=5
#
# Lighter defaults to avoid freezing the host (YOLO + PyTorch can use all cores otherwise):
# DETECTOR_CPU_THREADS=2
# DETECTOR_STREAM_FPS=4
# DETECTOR_INFER_FPS=1
# DETECTOR_IMG_SIZE=416
# Second model + extra inference per frame — leave off unless you need pose-based "fallen" hints:
# DETECTOR_ENABLE_POSE=false

# Optional: Protect POST /api/sos (mobile SOS) with x-api-key.
NETRA_SOS_API_KEY=

# Dashboard: show "EDGE CV" badge when inference is colocated on payload hardware (demo flag).
# NEXT_PUBLIC_EDGE_INFERENCE=false
